FROM python:3.13-slim

# Backend base image. Tex compilation now lives in the tex_translation service,
# so we no longer ship texlive-full here.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        poppler-utils \
        libgl1 \
        libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

RUN pip install uv

WORKDIR /app
