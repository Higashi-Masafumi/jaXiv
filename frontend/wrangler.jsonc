{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jaxiv-frontend",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true,
  },
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "API_BASE_URL": "http://arxiv-translation-service.onrender.com"
  },
  "main": "./workers/app.ts",
  "compatibility_flags": ["nodejs_compat"],
}
